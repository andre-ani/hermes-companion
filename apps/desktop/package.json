{
  "name": "@hermes-companion/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "electron": "electron .",
    "electron:uat": "node scripts/electron-uat.mjs",
    "release:checksums": "node scripts/release-checksums.mjs",
    "release:verify": "node scripts/verify-release-checksums.mjs",
    "dist": "npm run build && node scripts/write-build-provenance.mjs && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@hermes-companion/contracts": "*",
    "@hermes-companion/hermes-adapter": "*",
    "@hermes/shared": "*",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@shikijs/themes": "^4.3.1",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "ai": "^6.0.224",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "mode-watcher": "^1.1.0",
    "node-pty": "^1.1.0",
    "runed": "^0.37.1",
    "streamdown-svelte": "^3.0.6",
    "svelte": "^5.56.4",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.24.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "paneforge": "^1.0.2",
    "svelte-check": "^4.7.2",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "org.hermes.companion",
    "productName": "Hermes Companion",
    "directories": {
      "output": "electron-dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "build/build-provenance.json",
        "to": "build-provenance.json"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
