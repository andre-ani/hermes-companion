{
  "name": "hermes-companion",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": ["apps/*", "packages/*", "vendor/hermes-agent/apps/shared"],
  "scripts": {
    "dev": "npm run dev --workspace=@hermes-companion/desktop",
    "build": "npm run build --workspace=@hermes-companion/desktop && npm run build --workspace=@hermes-companion/bridge",
    "check": "npm run check --workspace=@hermes-companion/desktop && npm run check --workspace=@hermes-companion/bridge",
    "test": "vitest run tests",
    "architecture:check": "node scripts/check-architecture.mjs",
    "acceptance:live-railway-chat": "node scripts/live-railway-chat-recovery-acceptance.mjs",
    "acceptance:live-railway-coding-run": "node scripts/live-railway-coding-run-recovery-acceptance.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
